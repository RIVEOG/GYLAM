# ====================================================================
# Panel Configuration
# Copy this file to .env and fill in your values.
# ====================================================================

# ---- Supabase (auto-provisioned by Bolt; leave as-is) ----
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=your_db_url

# ====================================================================
# First Admin Account
# The panel auto-creates this admin on first run when the user signs up
# with this email. Set username/email/password before deploying.
# ====================================================================
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD=changeme123
VITE_ADMIN_USERNAME=admin

# ====================================================================
# Nodes
# Define each compute node. The id is a slug used to reference the node.
# status: offline | online
# ip_assigned: the node's IP address or domain name
# ====================================================================
VITE_NODE_1_STATUS=offline
VITE_NODE_1_IP=node1.example.com

VITE_NODE_2_STATUS=offline
VITE_NODE_2_IP=node2.example.com

VITE_NODE_3_STATUS=offline
VITE_NODE_3_IP=node3.example.com
