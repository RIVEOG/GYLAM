# Gylam Panel — Configuration
# Copy this file to .env and fill in your values.
# Made with Nethost Team.

# ---- Panel branding ----
VITE_PANEL_NAME=Gylam Panel

# ---- API server ----
API_PORT=3001
JWT_SECRET=change-this-to-a-random-secret
ADMIN_BOOTSTRAP_SECRET=gylam-bootstrap

# ---- Frontend API base (where the browser reaches the API) ----
# In dev mode, /api is proxied to localhost:3001 automatically.
VITE_API_BASE=/api

# ---- Node defaults ----
NODE_HEARTBEAT_INTERVAL=30
