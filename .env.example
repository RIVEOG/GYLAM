# Gylam Panel — Configuration
# Copy this file to .env and fill in your values.
# Made with Nethost Team.

# ---- Panel branding ----
VITE_PANEL_NAME=Gylam Panel

# ---- API server ----
API_PORT=3001
JWT_SECRET=change-this-to-a-random-secret
ADMIN_BOOTSTRAP_SECRET=gylam-bootstrap

# ---- Frontend API base (where the browser reaches the API) ----
# In production, set this to your server URL, e.g. http://your-ip:3001/api
VITE_API_BASE=/api

# ---- Supabase (optional — used for game server data) ----
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Node defaults ----
NODE_HEARTBEAT_INTERVAL=30
